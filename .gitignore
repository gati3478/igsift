# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Personal data — NEVER commit a real Instagram export
/ig_data/
/export/
/exports/
/ig-exported-data/
*.zip

# Archive extraction caches — written by `archive::resolve` next to the
# input. Hidden but still need ignoring in case an export lives inside
# the repo for testing.
.ig-mgr-extracted/
.ig-mgr-extracted-*/

# Generated audit artifacts
following-audit_*.csv
following-audit_*.md
# Legacy stem from before the 2026-05 rename — kept so an old run sitting
# in someone's working tree doesn't accidentally land in a commit.
recommendations_*.csv
recommendations_*.md

# Personal labels file — handle → user intent (keep / drop). Per-user data,
# never committed. `config/labels.txt.example` is the checked-in template.
/config/labels.txt

# Personal keep-allowlist — handles the user wants protected from Unfollow.
# Per-user data, never committed. `config/keep_allowlist.txt.example` is the
# checked-in template; copy to `config/keep_allowlist.txt` to activate.
/config/keep_allowlist.txt

# insta: uncommitted pending snapshots (review then accept with `cargo insta`)
*.snap.new
*.pending-snap

# Editor / OS cruft
.DS_Store
*.swp

# Claude Code / session tooling (local, machine-specific)
/.claude/
/.remember/
/tasks/
