# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Personal data — NEVER commit a real Instagram export
/ig_data/
/export/
/exports/
/ig-exported-data/
/downloaded-ig-data/
*.zip

# Archive extraction caches — written by `archive::resolve` next to the
# input. Hidden but still need ignoring in case an export lives inside
# the repo for testing.
.igsift-extracted/
.igsift-extracted-*/

# Generated audit artifacts
following-audit_*.csv
following-audit_*.md
following-audit_*.html
# Legacy stem from before the 2026-05 rename — kept so an old run sitting
# in someone's working tree doesn't accidentally land in a commit.
recommendations_*.csv
recommendations_*.md

# Personal labels file — handle → user intent (keep / drop). Per-user data,
# never committed. `config/labels.txt.example` is the checked-in template.
/config/labels.txt

# Personal keeplist — handles the user wants protected from Unfollow.
# Per-user data, never committed. `config/keeplist.txt.example` is the
# checked-in template; copy to `config/keeplist.txt` to activate.
/config/keeplist.txt

# Personal droplist — handles the user wants forced into Unfollow. The exact
# inverse of the keeplist. Per-user data, never committed.
# `config/droplist.txt.example` is the checked-in template; copy to
# `config/droplist.txt` to activate.
/config/droplist.txt

# cargo-mutants scratch output (regenerated each `cargo mutants` run)
/mutants.out/
/mutants.out.old/

# Editor / OS cruft
.DS_Store
*.swp

# Claude Code / session tooling (local, machine-specific)
/.claude/
/.remember/
/tasks/

# Local Playwright browser-test harness (browser binary + node_modules; never committed)
/.playwright-harness/
