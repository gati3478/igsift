#!/bin/sh
# Fail-fast format gate — mirrors CI's `cargo fmt --all -- --check` so a
# misformatted change is caught here, before it reaches CI.
#
# Fix with `cargo fmt --all`, or bypass deliberately with `git commit --no-verify`.
# Activate once per clone: git config core.hooksPath .githooks
if ! cargo fmt --all -- --check; then
    echo >&2
    echo "pre-commit: rustfmt check failed — run 'cargo fmt --all', then re-stage." >&2
    exit 1
fi
